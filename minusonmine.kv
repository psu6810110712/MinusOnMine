<MenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: 0.2

        Label:
            text: 'MinusOnMine'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '56sp'
            bold: True
            color: 1, 0.84, 0, 1
            size_hint_y: None
            height: self.texture_size[1]

        Label:
            text: 'Welcome Back, Miner!'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '24sp'
            color: 0.7, 0.7, 0.8, 1
            size_hint_y: None
            height: self.texture_size[1]

        Widget:
            size_hint_y: 0.2

        Button:
            text: 'Start Mining'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.18, 0.8, 0.44, 1
            color: 1, 1, 1, 1
            on_press: root.manager.current = 'map'

        Button:
            text: 'Settings'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.3, 0.3, 0.3, 1

        Button:
            text: 'Exit Game'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.8, 0.2, 0.2, 1
            on_press: app.stop()


        Widget:
            size_hint_y: 0.05

        Label:
            text: 'v0.2.2'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '12sp'
            color: 0.4, 0.4, 0.5, 1
            size_hint_y: 0.07



<MapScreen>:
    FloatLayout:
        RelativeLayout:
            id: world_layer
            size_hint: None, None
            size: 2400, 2400

            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1 
                Rectangle:
                    pos: 0, 0
                    size: self.size
                    source: 'ground.png' 

            PlayerWidget:
                id: player_character
                pos: 1000, 800


        Widget:
            id: fog_overlay
            size_hint: 1, 1
        Label:
            text: 'v0.2.1'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '14sp'
            color: 1, 1, 1, 0.8
            size_hint: None, None
            size: 100, 30
            pos_hint: {'x': 0.01, 'y': 0.01}

        Label:
            text: root.controls_hint
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '16sp'
            color: 1, 0.9, 0.6, 0.9
            size_hint: None, None
            size: 760, 40
            pos_hint: {'center_x': 0.5, 'y': 0.02}

        Button:
            text: 'Back to Menu'
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            size_hint: None, None
            size: 150, 50
            pos_hint: {'right': 0.98, 'top': 0.98}
            background_color: 0.8, 0.2, 0.2, 1
            on_press: root.manager.current = 'menu'

        Widget:
            id: minimap_widget
            size_hint: None, None
            size: 200, 200
            pos_hint: {'x': 0.01, 'top': 0.98}
            canvas.before:
                Color:
                    rgba: 0.8, 0.8, 0.8, 0.6
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.05, 0.05, 0.08, 0.85
                Rectangle:
                    pos: self.x + 2, self.y + 2
                    size: self.width - 4, self.height - 4

        BoxLayout:
            id: inventory_overlay
            orientation: 'vertical'
            size_hint: 0.85, 0.85
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: dp(25)
            spacing: dp(15)
            opacity: 0
            disabled: True
            
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 0.95  # Dark subtle background
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20]
                Color:
                    rgba: 0.8, 0.6, 0.2, 1  # Golden border
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 20)
                    width: dp(2)
                    
            BoxLayout:
                size_hint_y: 0.15
                orientation: 'horizontal'
                
                Label:
                    text: 'INVENTORY'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '36sp'
                    color: 1, 0.9, 0.4, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.5
                    Label:
                        id: inventory_capacity_label
                        text: 'Capacity: 0 / 20'
                        font_name: 'assets/fonts/PixelifySans-Medium.ttf'
                        font_size: '20sp'
                        color: 0.8, 0.8, 0.8, 1
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: inventory_money_label
                        text: 'Money: '
                        font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                        font_size: '22sp'
                        color: 0.2, 0.9, 0.4, 1
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                        
            Widget:
                size_hint_y: None
                height: dp(2)
                canvas:
                    Color:
                        rgba: 0.4, 0.4, 0.4, 0.5
                    Rectangle:
                        pos: self.pos
                        size: self.size
                
            ScrollView:
                size_hint_y: 0.85
                GridLayout:
                    id: inventory_grid
                    cols: max(4, int(self.width / dp(140)))
                    padding: dp(15)
                    spacing: dp(20)
                    size_hint_y: None
                    height: self.minimum_height
        
        SellOverlay:
            id: sell_overlay
            orientation: 'vertical'
            size_hint: 0.8, 0.9
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: 20
            spacing: 15
            opacity: 0
            disabled: True
            
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.12, 0.98
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]
                Color:
                    rgba: 0.2, 0.6, 0.9, 1
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, 15]
                    width: 2

            Label:
                text: 'MERCHANT'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '35sp'
                color: 0.4, 0.8, 1, 1
                size_hint_y: 0.1

            ScrollView:
                id: sell_scroll_view
                size_hint_y: 0.7
                do_scroll_x: False
                do_scroll_y: True
                BoxLayout:
                    id: sell_items_container
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(10)
                    padding: dp(10)

            BoxLayout:
                size_hint_y: 0.2
                orientation: 'horizontal'
                spacing: 20
                Label:
                    id: total_sell_label
                    text: 'Total Earned: $0'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '24sp'
                    color: 0.2, 0.9, 0.4, 1
                
                Button:
                    text: 'CLOSE'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '20sp'
                    background_color: 0.8, 0.2, 0.2, 1
                    on_press: root.toggle_sell_menu()

                Button:
                    id: buy_torch_button
                    text: 'BUY TORCH'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '20sp'
                    background_color: 0.95, 0.65, 0.2, 1
                    on_press: root.buy_torch()
                    disabled: True

                Button:
                    text: 'CONFIRM SELL'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '20sp'
                    background_color: 0.2, 0.7, 0.3, 1
                    on_press: root.confirm_sell()
        BoxLayout:
            id: upgrade_overlay
            orientation: 'vertical'
            size_hint: 0.6, 0.6
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: 20
            spacing: 15
            disabled: True
            opacity: 0
            
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 0.95
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]
                Color:
                    rgba: 1, 0.8, 0, 1
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, 15]
                    width: 2

            Label:
                text: 'BLACKSMITH'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '35sp'
                color: 1, 0.8, 0, 1
                size_hint_y: 0.2

            Label:
                id: upgrade_info_label
                text: 'Pickaxe Lv.1\nMining Speed: Normal\n\nNext Level Cost:\n10 Stone'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '20sp'
                halign: 'center'
                color: 1, 1, 1, 1

            Button:
                id: btn_buy_upgrade
                text: 'UPGRADE NOW'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '25sp'
                size_hint_y: 0.3
                background_color: 0.2, 0.7, 0.3, 1
                on_press: root.buy_upgrade()

        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            size: 240, 140
            pos_hint: {'right': 0.99, 'top': 0.88}
            padding: 10
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.1, 0.7
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
            
            Label:
                id: level_label
                text: 'Lv. 1'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '22sp'
                color: 1, 0.8, 0, 1
                text_size: self.size
                halign: 'left'
                valign: 'bottom'

            Label:
                id: exp_label
                text: 'EXP: 0 / 100'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '14sp'
                color: 1, 1, 1, 1
                text_size: self.size
                halign: 'left'
                valign: 'middle'

            Label:
                id: hud_money_label
                text: 'Money: $0'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '18sp'
                color: 0.2, 0.9, 0.4, 1
                text_size: self.size
                halign: 'left'
                valign: 'top'

            Label:
                id: hud_torch_label
                text: 'Torch: 0 | 00:00'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '16sp'
                color: 1, 0.85, 0.45, 1
                text_size: self.size
                halign: 'left'
                valign: 'top'

            Label:
                id: stamina_label
                text: 'Energy: 100 / 100'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '16sp'
                color: 0.2, 0.8, 1, 1
                text_size: self.size
                halign: 'left'
                valign: 'top'

<PlayerWidget>:
    size_hint: None, None
    size: 100, 100
    canvas:
        Color:
            rgba: 1, 1, 1, 1 
        Rectangle:
            pos: self.x + root.render_offset[0], self.y + root.render_offset[1]
            size: root.render_size
            source: root.image_source



<InventorySlot>:
    size_hint: None, None
    size: 80, 80
    
    canvas.before:
        Color:
            rgba: 0.25, 0.25, 0.3, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.5, 0.5, 0.5, 1
        Line:
            rectangle: (self.x, self.y, self.width, self.height)
            width: 1.5

    Image:
        source: root.item_image
        size: 50, 50
        pos: root.x + 15, root.y + 20

        Label:
            text: root.item_count
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '16sp'
            color: 1, 1, 1, 1
            size: 20, 20
            pos: root.right - 25, root.y + 5


<SellItemRow>:
    size_hint_y: None
    height: dp(80) # Increased height
    spacing: dp(15)
    padding: [dp(10), dp(5)]
    canvas.before:
        Color:
            rgba: 0.18, 0.18, 0.22, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    Image:
        source: root.item_image
        size_hint_x: 0.12

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.2
        Label:
            text: root.ore_name.capitalize()
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            font_size: '20sp'
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: f"Owned: {root.max_amount}"
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '14sp'
            color: 0.7, 0.7, 0.7, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'

    BoxLayout:
        orientation: 'horizontal'
        size_hint_x: 0.5
        spacing: dp(8)
        
        Button:
            text: '-'
            size_hint_x: None
            width: dp(40)
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            background_color: 0.6, 0.3, 0.3, 1
            on_press: root.adjust_quantity(-1)
            
        BoxLayout:
            orientation: 'vertical'
            Slider:
                id: sell_slider
                min: 0
                max: root.max_amount
                step: 1
                value: root.current_selected_amount
                on_value: root.on_slider_change(self.value)
            Label:
                text: f"Sell: {int(sell_slider.value)}"
                font_name: 'assets/fonts/PixelifySans-Medium.ttf'
                font_size: '16sp'
                size_hint_y: 0.4

        Button:
            text: '+'
            size_hint_x: None
            width: dp(40)
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            background_color: 0.3, 0.6, 0.3, 1
            on_press: root.adjust_quantity(1)

        Button:
            text: 'MAX'
            size_hint_x: None
            width: dp(60)
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            background_color: 0.2, 0.5, 0.8, 1
            on_press: root.set_max()

    Label:
        text: f"${root.subtotal}"
        font_name: 'assets/fonts/PixelifySans-Bold.ttf'
        font_size: '22sp'
        color: 0.2, 0.9, 0.4, 1
        size_hint_x: 0.18
