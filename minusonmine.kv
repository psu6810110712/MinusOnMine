# minusonmine.kv - à¹„à¸Ÿà¸¥à¹Œà¸­à¸­à¸à¹à¸šà¸š UI à¸‚à¸­à¸‡à¹€à¸à¸¡ MinusOnMine
# à¹ƒà¸Šà¹‰ Kivy Language à¸ªà¸³à¸«à¸£à¸±à¸šà¸ˆà¸±à¸”à¸à¸²à¸£ Widget à¹à¸¥à¸° Layout

# =============================================
# à¸«à¸™à¹‰à¸² Menu (MenuScreen)
# =============================================
<MenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 20

        # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡à¸ªà¸µà¹€à¸‚à¹‰à¸¡
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # à¸Šà¹ˆà¸­à¸‡à¸§à¹ˆà¸²à¸‡à¸”à¹‰à¸²à¸™à¸šà¸™
        Widget:
            size_hint_y: 0.2

        # à¸Šà¸·à¹ˆà¸­à¹€à¸à¸¡
        Label:
            text: 'MinusOnMine'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '56sp'
            bold: True
            color: 1, 0.84, 0, 1
            size_hint_y: None
            height: self.texture_size[1]

        # à¸„à¸³à¸­à¸˜à¸´à¸šà¸²à¸¢à¹€à¸à¸¡
        Label:
            text: 'Welcome Back, Miner!'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '24sp'
            color: 0.7, 0.7, 0.8, 1
            size_hint_y: None
            height: self.texture_size[1]

        # à¸Šà¹ˆà¸­à¸‡à¸§à¹ˆà¸²à¸‡
        Widget:
            size_hint_y: 0.2

        # à¸›à¸¸à¹ˆà¸¡à¹€à¸£à¸´à¹ˆà¸¡à¹€à¸à¸¡
        Button:
            text: 'Start Mining'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.18, 0.8, 0.44, 1
            color: 1, 1, 1, 1
            on_press: root.manager.current = 'map'

        # à¹€à¸žà¸´à¹ˆà¸¡à¸›à¸¸à¹ˆà¸¡à¸•à¸±à¹‰à¸‡à¸„à¹ˆà¸² (Settings)
        Button:
            text: 'Settings'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.3, 0.3, 0.3, 1

        # à¹€à¸žà¸´à¹ˆà¸¡à¸›à¸¸à¹ˆà¸¡à¸­à¸­à¸à¸ˆà¸²à¸à¹€à¸à¸¡ (Exit)
        Button:
            text: 'Exit Game'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.8, 0.2, 0.2, 1
            on_press: app.stop() # à¸„à¸³à¸ªà¸±à¹ˆà¸‡à¸›à¸´à¸”à¹à¸­à¸› Kivy


        # à¸Šà¹ˆà¸­à¸‡à¸§à¹ˆà¸²à¸‡à¸”à¹‰à¸²à¸™à¸¥à¹ˆà¸²à¸‡
        Widget:
            size_hint_y: 0.05

        # à¹€à¸§à¸­à¸£à¹Œà¸Šà¸±à¸™
        Label:
            text: 'v0.2.2'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '12sp'
            color: 0.4, 0.4, 0.5, 1
            size_hint_y: 0.07


# =============================================
# à¸«à¸™à¹‰à¸²à¹à¸œà¸™à¸—à¸µà¹ˆà¸‚à¸¸à¸”à¹à¸£à¹ˆ (MapScreen)
# =============================================
<MapScreen>:
    FloatLayout:
        # ===== 1. à¹€à¸¥à¹€à¸¢à¸­à¸£à¹Œà¸‚à¸­à¸‡à¹‚à¸¥à¸ (World Layer) =====
        # à¹€à¸£à¸²à¸ˆà¸°à¸à¸³à¸«à¸™à¸”à¹ƒà¸«à¹‰à¹‚à¸¥à¸à¹ƒà¸«à¸à¹ˆà¸à¸§à¹ˆà¸²à¸«à¸™à¹‰à¸²à¸ˆà¸­à¸¡à¸²à¸à¹† (à¹€à¸Šà¹ˆà¸™ 2400x2400)
        RelativeLayout:
            id: world_layer
            size_hint: None, None
            size: 2400, 2400  #à¸›à¸£à¸±à¸šà¸„à¸§à¸²à¸¡à¹ƒà¸«à¸à¹ˆà¸‚à¸­à¸‡à¹à¸¡à¸žà¸•à¸£à¸‡à¸™à¸µà¹‰

            # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡à¹à¸œà¸™à¸—à¸µà¹ˆà¸£à¸¹à¸›à¸ à¸²à¸ž
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1 
                Rectangle:
                    pos: 0, 0
                    size: self.size
                    source: 'ground.png' 

            # à¸•à¸±à¸§à¸¥à¸°à¸„à¸£ (à¹ƒà¸«à¹‰à¸­à¸¢à¸¹à¹ˆà¸‚à¹‰à¸²à¸‡à¹ƒà¸™ World)
            PlayerWidget:
                id: player_character
                pos: 1000, 800 # à¹ƒà¸«à¹‰à¹€à¸£à¸´à¹ˆà¸¡à¹€à¸à¸´à¸”à¸—à¸µà¹ˆà¸žà¸´à¸à¸±à¸”à¸™à¸µà¹‰


        Widget:
            id: fog_overlay
            size_hint: 1, 1
        # ===== 2. UI à¸šà¸™à¸«à¸™à¹‰à¸²à¸ˆà¸­ =====
        # à¹€à¸§à¸­à¸£à¹Œà¸Šà¸±à¸™à¸¡à¸¸à¸¡à¸‹à¹‰à¸²à¸¢à¸¥à¹ˆà¸²à¸‡
        Label:
            text: 'v0.2.1'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '14sp'
            color: 1, 1, 1, 0.8
            size_hint: None, None
            size: 100, 30
            pos_hint: {'x': 0.01, 'y': 0.01}

        # à¸„à¸³à¹à¸™à¸°à¸™à¸³à¸›à¸¸à¹ˆà¸¡à¸Šà¹ˆà¸­à¸‡à¹€à¸à¹‡à¸šà¸‚à¸­à¸‡ (à¸•à¸£à¸‡à¸à¸¥à¸²à¸‡à¸¥à¹ˆà¸²à¸‡)
        Label:
            text: '[ Press I or Tab to open Inventory ]'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '16sp'
            color: 1, 0.9, 0.6, 0.9
            size_hint: None, None
            size: 300, 40
            pos_hint: {'center_x': 0.5, 'y': 0.02}

        # à¸›à¸¸à¹ˆà¸¡à¸à¸¥à¸±à¸šà¹€à¸¡à¸™à¸¹ (à¸­à¸¢à¸¹à¹ˆà¸™à¸­à¸ World à¹€à¸§à¸¥à¸²à¸à¸¥à¹‰à¸­à¸‡à¹€à¸¥à¸·à¹ˆà¸­à¸™ à¸›à¸¸à¹ˆà¸¡à¸ˆà¸°à¹„à¸¡à¹ˆà¹€à¸¥à¸·à¹ˆà¸­à¸™à¸•à¸²à¸¡)
        Button:
            text: 'Back to Menu'
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            size_hint: None, None
            size: 150, 50
            pos_hint: {'right': 0.98, 'top': 0.98}
            background_color: 0.8, 0.2, 0.2, 1
            on_press: root.manager.current = 'menu'

        # ===== 3. Minimap (à¸‹à¹‰à¸²à¸¢à¸šà¸™) =====
        Widget:
            id: minimap_widget
            size_hint: None, None
            size: 200, 200
            pos_hint: {'x': 0.01, 'top': 0.98}
            # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡ minimap
            canvas.before:
                # à¸à¸£à¸­à¸šà¸™à¸­à¸ (à¸‚à¸­à¸šà¸ªà¸µà¸‚à¸²à¸§)
                Color:
                    rgba: 0.8, 0.8, 0.8, 0.6
                Rectangle:
                    pos: self.pos
                    size: self.size
                # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡à¸”à¸³
                Color:
                    rgba: 0.05, 0.05, 0.08, 0.85
                Rectangle:
                    pos: self.x + 2, self.y + 2
                    size: self.width - 4, self.height - 4

        # ===== 4. Inventory Overlay =====
        BoxLayout:
            id: inventory_overlay
            orientation: 'vertical'
            size_hint: 0.85, 0.85
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: dp(25)
            spacing: dp(15)
            # Hide by default
            opacity: 0
            disabled: True
            
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 0.95  # Dark subtle background
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20]
                # Outer Border
                Color:
                    rgba: 0.8, 0.6, 0.2, 1  # Golden border
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 20)
                    width: dp(2)
                    
            # Header Layout (Title + Capacity + Money)
            BoxLayout:
                size_hint_y: 0.15
                orientation: 'horizontal'
                
                Label:
                    text: 'INVENTORY'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '36sp'
                    color: 1, 0.9, 0.4, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.5
                    Label:
                        id: inventory_capacity_label
                        text: 'Capacity: 0 / 20'
                        font_name: 'assets/fonts/PixelifySans-Medium.ttf'
                        font_size: '20sp'
                        color: 0.8, 0.8, 0.8, 1
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: inventory_money_label
                        text: 'Money: '
                        font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                        font_size: '22sp'
                        color: 0.2, 0.9, 0.4, 1
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                        
            # Subtle divider line
            Widget:
                size_hint_y: None
                height: dp(2)
                canvas:
                    Color:
                        rgba: 0.4, 0.4, 0.4, 0.5
                    Rectangle:
                        pos: self.pos
                        size: self.size
                
            ScrollView:
                size_hint_y: 0.85
                GridLayout:
                    id: inventory_grid
                    # Use adaptive columns based on width, min 4 cols
                    cols: max(4, int(self.width / dp(140)))
                    padding: dp(15)
                    spacing: dp(20)
                    size_hint_y: None
                    height: self.minimum_height
        
        # ==========================================
        # à¸«à¸™à¹‰à¸²à¸•à¹ˆà¸²à¸‡à¸‚à¸²à¸¢à¹à¸£à¹ˆà¹ƒà¸«à¹‰ NPC (Sell Overlay)
        # ==========================================
        SellOverlay:
            id: sell_overlay
            orientation: 'vertical'
            size_hint: 0.8, 0.9
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: 20
            spacing: 15
            opacity: 0
            disabled: True
            
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.12, 0.98
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]
                Color:
                    rgba: 0.2, 0.6, 0.9, 1
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, 15]
                    width: 2

            Label:
                text: 'MERCHANT'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '35sp'
                color: 0.4, 0.8, 1, 1
                size_hint_y: 0.1

            # à¸¥à¸´à¸ªà¸•à¹Œà¸ªà¸´à¸™à¸„à¹‰à¸²
            ScrollView:
                id: sell_scroll_view
                size_hint_y: 0.7
                do_scroll_x: False
                do_scroll_y: True
                BoxLayout:
                    id: sell_items_container
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(10)
                    padding: dp(10)

            # à¸ªà¹ˆà¸§à¸™à¸ªà¸£à¸¸à¸›à¹à¸¥à¸°à¸›à¸¸à¹ˆà¸¡à¸à¸”à¸¢à¸·à¸™à¸¢à¸±à¸™
            BoxLayout:
                size_hint_y: 0.2
                orientation: 'horizontal'
                spacing: 20
                Label:
                    id: total_sell_label
                    text: 'Total Earned: $0'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '24sp'
                    color: 0.2, 0.9, 0.4, 1
                
                Button:
                    text: 'CLOSE'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '20sp'
                    background_color: 0.8, 0.2, 0.2, 1
                    on_press: root.toggle_sell_menu()

                Button:
                    id: buy_torch_button
                    text: 'BUY TORCH'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '20sp'
                    background_color: 0.95, 0.65, 0.2, 1
                    on_press: root.buy_torch()
                    disabled: True

                Button:
                    text: 'CONFIRM SELL'
                    font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                    font_size: '20sp'
                    background_color: 0.2, 0.7, 0.3, 1
                    on_press: root.confirm_sell()
        # ==========================================
        # à¸«à¸™à¹‰à¸²à¸•à¹ˆà¸²à¸‡à¸­à¸±à¸›à¹€à¸à¸£à¸”à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­ (Upgrade Overlay)
        # ==========================================
        BoxLayout:
            id: upgrade_overlay
            orientation: 'vertical'
            size_hint: 0.6, 0.6
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: 20
            spacing: 15
            disabled: True   # à¸‹à¹ˆà¸­à¸™à¹„à¸§à¹‰à¸•à¸­à¸™à¹€à¸£à¸´à¹ˆà¸¡à¹€à¸à¸¡
            opacity: 0
            
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 0.95  # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡à¸ªà¸µà¹€à¸—à¸²à¹€à¸‚à¹‰à¸¡à¹‚à¸›à¸£à¹ˆà¸‡à¹à¸ªà¸‡
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]
                Color:
                    rgba: 1, 0.8, 0, 1  # à¸‚à¸­à¸šà¸ªà¸µà¸—à¸­à¸‡
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, 15]
                    width: 2

            Label:
                text: 'BLACKSMITH'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf' # à¹ƒà¸Šà¹‰à¸Ÿà¸­à¸™à¸•à¹Œà¸‚à¸­à¸‡à¸„à¸¸à¸“
                font_size: '35sp'
                color: 1, 0.8, 0, 1
                size_hint_y: 0.2

            Label:
                id: upgrade_info_label
                text: 'Pickaxe Lv.1\nMining Speed: Normal\n\nNext Level Cost:\n10 Stone'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '20sp'
                halign: 'center'
                color: 1, 1, 1, 1

            Button:
                id: btn_buy_upgrade
                text: 'UPGRADE NOW'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '25sp'
                size_hint_y: 0.3
                background_color: 0.2, 0.7, 0.3, 1
                on_press: root.buy_upgrade()

        # HUD: à¹à¸ªà¸”à¸‡ Level, EXP à¹à¸¥à¸° Money (à¸¡à¸¸à¸¡à¸‚à¸§à¸²à¸šà¸™)
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            size: 240, 140
            pos_hint: {'right': 0.99, 'top': 0.88} # à¸§à¸²à¸‡à¸¡à¸¸à¸¡à¸‚à¸§à¸²à¸šà¸™ (à¹ƒà¸•à¹‰à¸›à¸¸à¹ˆà¸¡ Back to Menu)
            padding: 10
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.1, 0.7  # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡à¸ªà¸µà¸”à¸³à¹‚à¸›à¸£à¹ˆà¸‡à¹à¸ªà¸‡
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
            
            Label:
                id: level_label
                text: 'Lv. 1'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '22sp'
                color: 1, 0.8, 0, 1  # à¸ªà¸µà¸—à¸­à¸‡
                text_size: self.size
                halign: 'left'
                valign: 'bottom'

            Label:
                id: exp_label
                text: 'EXP: 0 / 100'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '14sp'
                color: 1, 1, 1, 1
                text_size: self.size
                halign: 'left'
                valign: 'middle'

            Label:
                id: hud_money_label
                text: 'Money: $0'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '18sp'
                color: 0.2, 0.9, 0.4, 1
                text_size: self.size
                halign: 'left'
                valign: 'top'

            Label:
                id: hud_torch_label
                text: 'Torch: 0 | 00:00'
                font_name: 'assets/fonts/PixelifySans-Bold.ttf'
                font_size: '16sp'
                color: 1, 0.85, 0.45, 1
                text_size: self.size
                halign: 'left'
                valign: 'top'

# =============================================
# à¸ªà¸£à¹‰à¸²à¸‡à¸«à¸™à¹‰à¸²à¸•à¸²à¸‚à¸­à¸‡à¸•à¸±à¸§à¸¥à¸°à¸„à¸£ (Player)
# =============================================
<PlayerWidget>:
    size_hint: None, None
    size: 100, 100
    canvas:
        Color:
            rgba: 1, 1, 1, 1 
        Rectangle:
            pos: self.x + root.render_offset[0], self.y + root.render_offset[1]
            size: root.render_size
            source: root.image_source


# =============================================
# à¸Šà¹ˆà¸­à¸‡à¹€à¸à¹‡à¸šà¸‚à¸­à¸‡ (Inventory Slot)
# =============================================
<InventorySlot>:
    size_hint: None, None
    size: 80, 80
    
    canvas.before:
        # à¸žà¸·à¹‰à¸™à¸«à¸¥à¸±à¸‡à¸Šà¹ˆà¸­à¸‡à¹ƒà¸ªà¹ˆà¸‚à¸­à¸‡
        Color:
            rgba: 0.25, 0.25, 0.3, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # à¸à¸£à¸­à¸š
        Color:
            rgba: 0.5, 0.5, 0.5, 1
        Line:
            rectangle: (self.x, self.y, self.width, self.height)
            width: 1.5

    # à¸£à¸¹à¸›à¸ à¸²à¸žà¹„à¸­à¹€à¸—à¸¡à¸•à¸£à¸‡à¸à¸¥à¸²à¸‡
    Image:
        source: root.item_image
        size: 50, 50
        pos: root.x + 15, root.y + 20

        # à¸•à¸±à¸§à¹€à¸¥à¸‚à¸£à¸°à¸šà¸¸à¸ˆà¸³à¸™à¸§à¸™à¸¡à¸¸à¸¡à¸‚à¸§à¸²à¸¥à¹ˆà¸²à¸‡
        Label:
            text: root.item_count
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '16sp'
            color: 1, 1, 1, 1
            size: 20, 20
            pos: root.right - 25, root.y + 5

# =============================================
# à¹à¸–à¸§à¸ªà¸³à¸«à¸£à¸±à¸šà¸•à¸±à¹‰à¸‡à¸„à¹ˆà¸²à¸ˆà¸³à¸™à¸§à¸™à¸à¸²à¸£à¸‚à¸²à¸¢à¹à¸£à¹ˆ (Sell Menu)
# =============================================
<SellItemRow>:
    size_hint_y: None
    height: dp(80) # Increased height
    spacing: dp(15)
    padding: [dp(10), dp(5)]
    canvas.before:
        Color:
            rgba: 0.18, 0.18, 0.22, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    # à¸£à¸¹à¸›à¹„à¸­à¹€à¸—à¸¡
    Image:
        source: root.item_image
        size_hint_x: 0.12

    # à¸Šà¸·à¹ˆà¸­à¹à¸¥à¸°à¸ˆà¸³à¸™à¸§à¸™à¸—à¸µà¹ˆà¸¡à¸µ
    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.2
        Label:
            text: root.ore_name.capitalize()
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            font_size: '20sp'
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: f"Owned: {root.max_amount}"
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '14sp'
            color: 0.7, 0.7, 0.7, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'

    # Controls: - Slider + MAX
    BoxLayout:
        orientation: 'horizontal'
        size_hint_x: 0.5
        spacing: dp(8)
        
        Button:
            text: '-'
            size_hint_x: None
            width: dp(40)
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            background_color: 0.6, 0.3, 0.3, 1
            on_press: root.adjust_quantity(-1)
            
        BoxLayout:
            orientation: 'vertical'
            Slider:
                id: sell_slider
                min: 0
                max: root.max_amount
                step: 1
                value: root.current_selected_amount
                on_value: root.on_slider_change(self.value)
            Label:
                text: f"Sell: {int(sell_slider.value)}"
                font_name: 'assets/fonts/PixelifySans-Medium.ttf'
                font_size: '16sp'
                size_hint_y: 0.4

        Button:
            text: '+'
            size_hint_x: None
            width: dp(40)
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            background_color: 0.3, 0.6, 0.3, 1
            on_press: root.adjust_quantity(1)

        Button:
            text: 'MAX'
            size_hint_x: None
            width: dp(60)
            font_name: 'assets/fonts/PixelifySans-Bold.ttf'
            background_color: 0.2, 0.5, 0.8, 1
            on_press: root.set_max()

    # à¸£à¸²à¸„à¸²à¸£à¸§à¸¡
    Label:
        text: f"${root.subtotal}"
        font_name: 'assets/fonts/PixelifySans-Bold.ttf'
        font_size: '22sp'
        color: 0.2, 0.9, 0.4, 1
        size_hint_x: 0.18

