# minusonmine.kv - ไฟล์ออกแบบ UI ของเกม MinusOnMine
# ใช้ Kivy Language สำหรับจัดการ Widget และ Layout

# =============================================
# หน้า Menu (MenuScreen)
# =============================================
<MenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 20

        # พื้นหลังสีเข้ม
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # ช่องว่างด้านบน
        Widget:
            size_hint_y: 0.2

        # ชื่อเกม
        Label:
            text: 'MinusOnMine'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '56sp'
            bold: True
            color: 1, 0.84, 0, 1
            size_hint_y: None
            height: self.texture_size[1]

        # คำอธิบายเกม
        Label:
            text: 'Welcome Back, Miner!'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '24sp'
            color: 0.7, 0.7, 0.8, 1
            size_hint_y: None
            height: self.texture_size[1]

        # ช่องว่าง
        Widget:
            size_hint_y: 0.2

        # ปุ่มเริ่มเกม
        Button:
            text: 'Start Mining'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.18, 0.8, 0.44, 1
            color: 1, 1, 1, 1
            on_press: root.manager.current = 'mining'

        # เพิ่มปุ่มตั้งค่า (Settings)
        Button:
            text: 'Settings'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.3, 0.3, 0.3, 1
            #on_press: root.manager.current = 'settings' # รอสร้างหน้า Settings

        # เพิ่มปุ่มออกจากเกม (Exit)
        Button:
            text: 'Exit Game'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: None, None
            size: 400, 65
            pos_hint: {'center_x': 0.5}
            background_color: 0.8, 0.2, 0.2, 1
            on_press: app.stop() # คำสั่งปิดแอป Kivy

        # ช่องว่างด้านล่าง
        Widget:
            size_hint_y: 0.05

        # เวอร์ชัน
        Label:
            text: 'v0.1.0'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '12sp'
            color: 0.4, 0.4, 0.5, 1
            size_hint_y: 0.07


# =============================================
# หน้าขุดแร่ (MiningScreen) - โครงเปล่า
# =============================================
<MiningScreen>:
    BoxLayout:
        orientation: 'vertical'

        canvas.before:
            Color:
                rgba: 0.15, 0.13, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: 'Mining Screen - Coming Soon'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '25sp'
            color: 1, 0.84, 0, 1

        Button:
            text: 'Back to Menu'
            font_name: 'assets/fonts/PixelifySans-Medium.ttf'
            font_size: '22sp'
            size_hint: 0.4, 0.08
            size_hint_x: 400
            size_hint_y: 0
            pos_hint: {'center_x': 0.5}
            on_press: root.manager.current = 'menu'
